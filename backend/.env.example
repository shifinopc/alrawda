# Copy to .env (or set these as environment variables in cPanel → Setup Node.js App)
DB_HOST=localhost
DB_PORT=3306
DB_USER=cpaneluser_travels
DB_PASSWORD=change-me
DB_NAME=cpaneluser_travels

JWT_SECRET=put-a-long-random-string-here
JWT_EXPIRES=12h

# Allow the frontend origin (split deploy). Comma-separate for multiple.
CORS_ORIGIN=https://stimesapp.ionob.in

# PDF engine: leave unset to auto-detect Chrome; 'pdfkit' forces the browser-free renderer.
PDF_ENGINE=pdfkit

# Do NOT set PORT — cPanel/Passenger injects it.
